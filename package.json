{
  "name": "smart-batching",
  "version": "0.0.0",
  "description": "Build composable ERC-8211 transaction batches with runtime values, on-chain constraints, and atomic pre/post conditions for EVM smart accounts.",
  "author": "Biconomy",
  "license": "MIT",
  "repository": "github:bcnmy/composable-sdk",
  "homepage": "https://erc8211.com/",
  "keywords": [
    "erc-8211",
    "composable",
    "composability",
    "smart account",
    "chain abstraction",
    "gas abstraction",
    "account abstraction",
    "biconomy",
    "sdk"
  ],
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "release": "changeset publish",
    "version": "changeset version"
  },
  "devDependencies": {
    "@biconomy/abstractjs": "^1.2.4",
    "@biomejs/biome": "2.4.9",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@zerodev/ecdsa-validator": "^5.4.9",
    "@zerodev/sdk": "^5.5.10",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^5",
    "viem": "^2.47.6"
  }
}
